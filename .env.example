# ============================================================
# Signup Manager - Environment Configuration
# ============================================================
#
# PRODUCTION (vault mode - recommended):
#   Secrets are stored in an encrypted .vault file and entered
#   via the /unlock page at startup. Only non-secret config
#   goes here. Create the vault with: python vault.py create
#
# DEVELOPMENT (direct mode):
#   Put everything here including secrets. The app starts
#   immediately without requiring an unlock step.
# ============================================================

# --- Non-secret config (always set these) ---

# Database
DATABASE_URL=sqlite:////app/data/members.db

# CORS — set to your domain or external IP in production
FRONTEND_URL=http://localhost:5173

# JWT Settings
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480

# Vault file path (production)
VAULT_FILE=/app/data/.vault

# --- Email notifications (optional) ---
# Sign up at https://resend.com for a free API key (3,000 emails/month free)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# NOTIFICATION_EMAIL=your-email@example.com (comma-separated for multiple)
# From-address for all notification emails (must be a verified Resend domain)
# EMAIL_FROM_ADDRESS=Signup Manager <notifications@example.com>
# Notified when a member is marked vetted or needs follow-up (comma-separated OK)
# VETTING_NOTIFICATION_EMAIL=alex@indivisiblepaloaltoplus.org
# Notified for one-month / six-month follow-up pings (comma-separated OK)
# FOLLOWUP_NOTIFICATION_EMAIL=hi@indivisiblepaloaltoplus.org

# --- Secrets (development only — use vault for production) ---
# Generate with: python generate_keys.py
# SECRET_KEY=your-secret-key-here
# ENCRYPTION_KEY=your-fernet-key-here
# EMAIL_BLIND_INDEX_SALT=your-salt-here
# FIRST_RUN_ADMIN_USER=admin
# FIRST_RUN_ADMIN_PASSWORD=change-this-password
